{
    "version": 2,
    "cleanUrls": true,
    "builds": [
        {
            "src": "index.js",
            "use": "@vercel/node",
            "config": {
                "includeFiles": [
                    "*.html",
                    "*.css",
                    "*.js",
                    "*.json",
                    "*.svg"
                ]
            }
        }
    ],
    "rewrites": [
        {
            "source": "/(.*)",
            "destination": "/index.js"
        }
    ]
}