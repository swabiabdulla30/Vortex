{
    "version": 2,
    "cleanUrls": true,
    "builds": [
        {
            "src": "index.js",
            "use": "@vercel/node",
            "config": {
                "includeFiles": [
                    "**/*.html",
                    "**/*.css",
                    "**/*.js",
                    "**/*.json",
                    "**/*.svg",
                    "**/*.png",
                    "**/*.jpg",
                    "**/*.jpeg",
                    "**/*.gif",
                    "**/*.ico"
                ]
            }
        }
    ],
    "rewrites": [
        {
            "source": "/api/(.*)",
            "destination": "/index.js"
        },
        {
            "source": "/((?!.*\\..*).*)",
            "destination": "/index.js"
        }
    ]
}